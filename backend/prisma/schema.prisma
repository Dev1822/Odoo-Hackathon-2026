generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---- STUB SHARED MODELS (sync with team before final merge) ----
model Employee {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])
  role         Role     @default(EMPLOYEE)
  totalXp      Int      @default(0)  // denormalized cache; source of truth is XpLedgerEntry
  createdAt    DateTime @default(now())

  // Gamification relations
  challengeParticipations ChallengeParticipation[]
  employeeBadges          EmployeeBadge[]
  redemptions             RewardRedemption[]
  xpLedgerEntries         XpLedgerEntry[]
  notifications           Notification[]

  // Cross-module relations
  activityLogs            ActivityLog[]
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String
  code      String     @unique
  employees Employee[]

  // Environmental relations
  carbonTransactions CarbonTransaction[]
  environmentalGoals EnvironmentalGoal[]

  // Cross-module relations
  activityLogs       ActivityLog[]
  departmentScore    DepartmentScore?
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

model Category {
  id     Int            @id @default(autoincrement())
  name   String
  type   CategoryType
  status CategoryStatus @default(ACTIVE)

  challenges      Challenge[]
  emissionFactors EmissionFactor[]

  @@unique([name, type])
}

enum CategoryType {
  CSR_ACTIVITY
  CHALLENGE
  EMISSION_FACTOR
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

// ---- GAMIFICATION MODELS ----
model Challenge {
  id               Int             @id @default(autoincrement())
  title            String
  categoryId       Int
  category         Category        @relation(fields: [categoryId], references: [id])
  description      String          @db.Text
  xp               Int
  difficulty       Difficulty
  evidenceRequired Boolean         @default(false)
  deadline         DateTime?
  status           ChallengeStatus @default(DRAFT)
  createdById      Int
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  participations ChallengeParticipation[]

  @@index([status])
  @@index([categoryId])
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}
enum ChallengeStatus {
  DRAFT
  ACTIVE
  UNDER_REVIEW
  COMPLETED
  ARCHIVED
}

model ChallengeParticipation {
  id             Int            @id @default(autoincrement())
  challengeId    Int
  challenge      Challenge      @relation(fields: [challengeId], references: [id])
  employeeId     Int
  employee       Employee       @relation(fields: [employeeId], references: [id])
  progress       Int            @default(0)
  proofUrl       String?
  approvalStatus ApprovalStatus @default(PENDING)
  xpAwarded      Int            @default(0)
  joinedAt       DateTime       @default(now())
  completedAt    DateTime?

  @@unique([challengeId, employeeId])
  @@index([employeeId])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Badge {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @db.Text
  icon        String?
  unlockRule  Json
  createdAt   DateTime @default(now())

  employeeBadges EmployeeBadge[]
}

model EmployeeBadge {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  badgeId    Int
  badge      Badge    @relation(fields: [badgeId], references: [id])
  awardedAt  DateTime @default(now())

  @@unique([employeeId, badgeId])
}

model Reward {
  id             Int          @id @default(autoincrement())
  name           String
  description    String       @db.Text
  pointsRequired Int
  stock          Int          @default(0)
  status         RewardStatus @default(ACTIVE)

  redemptions RewardRedemption[]
}

enum RewardStatus {
  ACTIVE
  INACTIVE
}

model RewardRedemption {
  id             Int      @id @default(autoincrement())
  employeeId     Int
  employee       Employee @relation(fields: [employeeId], references: [id])
  rewardId       Int
  reward         Reward   @relation(fields: [rewardId], references: [id])
  pointsDeducted Int
  redeemedAt     DateTime @default(now())

  @@index([employeeId])
}

model XpLedgerEntry {
  id         Int          @id @default(autoincrement())
  employeeId Int
  employee   Employee     @relation(fields: [employeeId], references: [id])
  sourceType XpSourceType
  sourceId   Int?
  points     Int
  createdAt  DateTime     @default(now())

  @@index([employeeId])
}

enum XpSourceType {
  CHALLENGE
  CSR_ACTIVITY
  REDEMPTION
  ADJUSTMENT
}

model Notification {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  type       String
  payload    Json
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([employeeId])
}

// ---- ENVIRONMENTAL MODELS ----
model EmissionFactor {
  id          Int          @id @default(autoincrement())
  categoryId  Int
  category    Category     @relation(fields: [categoryId], references: [id])
  name        String
  unit        String       // e.g. "kgCO2e/kWh", "kgCO2e/liter"
  factorValue Decimal      @db.Decimal(12, 6)
  source      String?      // e.g. "DEFRA 2025", for audit trail
  validFrom   DateTime
  validTo     DateTime?
  status      FactorStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  carbonTransactions CarbonTransaction[]

  @@index([categoryId, status])
}

enum FactorStatus {
  ACTIVE
  INACTIVE
}

model ProductEsgProfile {
  id              Int      @id @default(autoincrement())
  productName     String
  productCode     String   @unique
  carbonFootprint Decimal  @db.Decimal(12, 4)
  recyclable      Boolean  @default(false)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  carbonTransactions CarbonTransaction[]
}

model CarbonTransaction {
  id               Int               @id @default(autoincrement())
  departmentId     Int
  department       Department        @relation(fields: [departmentId], references: [id])
  emissionFactorId Int
  emissionFactor   EmissionFactor    @relation(fields: [emissionFactorId], references: [id])
  productId        Int?
  product          ProductEsgProfile? @relation(fields: [productId], references: [id])
  sourceModule     SourceModule      // PURCHASE, MANUFACTURING, EXPENSE, FLEET, MANUAL
  sourceRecordId   Int?              // FK into whichever module's record (loose coupling)
  quantity         Decimal           @db.Decimal(12, 4) // e.g. liters, kWh consumed
  calculatedCo2e   Decimal           @db.Decimal(12, 4) // quantity * emissionFactor.factorValue
  autoCalculated   Boolean           @default(false)
  transactionDate  DateTime
  createdAt        DateTime          @default(now())

  @@index([departmentId, transactionDate])
  @@index([sourceModule])
}

enum SourceModule {
  PURCHASE
  MANUFACTURING
  EXPENSE
  FLEET
  MANUAL
}

model EnvironmentalGoal {
  id           Int        @id @default(autoincrement())
  name         String
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  targetCo2e   Decimal    @db.Decimal(12, 4)
  currentCo2e  Decimal    @db.Decimal(12, 4) @default(0) // recalculated, not manually edited
  deadline     DateTime
  status       GoalStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([departmentId, status])
}

enum GoalStatus {
  ACTIVE
  ON_TRACK
  AT_RISK
  COMPLETED
  ARCHIVED
}

// ---- SHARED CROSS-MODULE INFRASTRUCTURE ----
// Every module (Environmental, Social, Governance, Gamification) writes here.
// Agree on eventType naming with the team before adding new ones.
model ActivityLog {
  id           Int         @id @default(autoincrement())
  module       ModuleName
  eventType    String      // e.g. 'GOAL_COMPLETED', 'CSR_COMPLETED', 'COMPLIANCE_ISSUE_RAISED'
  description  String      // human-readable, pre-formatted
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])
  employeeId   Int?
  employee     Employee?   @relation(fields: [employeeId], references: [id])
  metadata     Json?
  createdAt    DateTime    @default(now())

  @@index([createdAt])
  @@index([module])
}

enum ModuleName {
  ENVIRONMENTAL
  SOCIAL
  GOVERNANCE
  GAMIFICATION
}

// Aggregated per-department score, recalculated whenever underlying data changes.
// Environmental writes environmentalScore; Social/Governance teammates will write
// their columns; totalScore is the weighted aggregate.
model DepartmentScore {
  id                 Int        @id @default(autoincrement())
  departmentId       Int        @unique
  department         Department @relation(fields: [departmentId], references: [id])
  environmentalScore Decimal    @db.Decimal(5, 2) @default(0)
  socialScore        Decimal    @db.Decimal(5, 2) @default(0)
  governanceScore    Decimal    @db.Decimal(5, 2) @default(0)
  totalScore         Decimal    @db.Decimal(5, 2) @default(0)
  lastCalculatedAt   DateTime   @updatedAt
}
